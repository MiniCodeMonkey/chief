{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cmd/prd-create.json",
  "title": "PRD Create Command",
  "description": "Command to create a new PRD in a project",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "prd-create"
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "device_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "properties": {
        "project_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID of the project to create the PRD in"
        },
        "title": {
          "type": "string",
          "description": "Title of the new PRD"
        },
        "content": {
          "type": "string",
          "description": "Initial content/description of the PRD"
        }
      },
      "required": ["project_id", "title", "content"],
      "additionalProperties": false
    }
  },
  "required": ["type", "id", "device_id", "timestamp", "payload"],
  "additionalProperties": false
}
