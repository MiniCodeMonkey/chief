{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cmd/run-stop.json",
  "title": "Run Stop Command",
  "description": "Command to stop a running execution",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "run-stop"
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "device_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "properties": {
        "run_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID of the run to stop"
        }
      },
      "required": ["run_id"],
      "additionalProperties": false
    }
  },
  "required": ["type", "id", "device_id", "timestamp", "payload"],
  "additionalProperties": false
}
