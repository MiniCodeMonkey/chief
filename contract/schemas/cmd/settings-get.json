{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cmd/settings-get.json",
  "title": "Settings Get Command",
  "description": "Command to retrieve current device settings",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "settings-get"
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "device_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "properties": {},
      "additionalProperties": false
    }
  },
  "required": ["type", "id", "device_id", "timestamp", "payload"],
  "additionalProperties": false
}
