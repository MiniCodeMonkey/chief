{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cmd/log-get.json",
  "title": "Log Get Command",
  "description": "Command to retrieve git log for a project",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "log-get"
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "device_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "properties": {
        "project_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID of the project to get logs for"
        },
        "limit": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum number of log entries to return"
        }
      },
      "required": ["project_id"],
      "additionalProperties": false
    }
  },
  "required": ["type", "id", "device_id", "timestamp", "payload"],
  "additionalProperties": false
}
